# Copy this to .env.local for local dev, or add to Vercel Dashboard → Settings → Environment Variables

# OpenAI API Key for Chatbot (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your_openai_api_key_here

SMTP_HOST=mail.iprofixer.com.my
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=for_services@iprofixer.com.my
SMTP_PASS=your_email_password_here
NOTIFY_EMAIL=for_services@iprofixer.com.my
