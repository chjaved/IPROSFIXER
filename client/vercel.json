{
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth.js" },
    { "source": "/api/users/:path*", "destination": "/api/users.js" },
    { "source": "/api/users", "destination": "/api/users.js" },
    { "source": "/api/bookings/:path*", "destination": "/api/bookings.js" },
    { "source": "/api/bookings", "destination": "/api/bookings.js" },
    { "source": "/api/services/:path*", "destination": "/api/services.js" },
    { "source": "/api/services", "destination": "/api/services.js" },
    { "source": "/api/reviews/:path*", "destination": "/api/reviews.js" },
    { "source": "/api/reviews", "destination": "/api/reviews.js" },
    { "source": "/api/transactions/:path*", "destination": "/api/transactions.js" },
    { "source": "/api/transactions", "destination": "/api/transactions.js" },
    { "source": "/api/payments/:path*", "destination": "/api/payments.js" },
    { "source": "/api/payments", "destination": "/api/payments.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/seed", "destination": "/api/seed.js" },
    { "source": "/api/seed-data", "destination": "/api/seed-data.js" },
    { "source": "/api/health", "destination": "/api/services.js" },
    { "source": "/api/contact", "destination": "/api/contact.js" },
    { "source": "/api/join", "destination": "/api/contact.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
