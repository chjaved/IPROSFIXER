    { "source": "/api/checklist-templates/:path*", "destination": "/api/jobs.js" },
    { "source": "/api/checklist-templates",      "destination": "/api/jobs.js" },
    { "source": "/api/reschedule/:path*",        "destination": "/api/jobs.js" },
    { "source": "/api/reschedule",               "destination": "/api/jobs.js" },
    { "source": "/api/health",                   "destination": "/api/services.js" },
    { "source": "/api/contact",                  "destination": "/api/contact.js" },
    { "source": "/api/join",                     "destination": "/api/contact.js" },
    { "source": "/((?!api/).*)",                 "destination": "/index.html" }
  ]
}
