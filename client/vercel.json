    { "source": "/api/services",                 "destination": "/api/services.js" },
    { "source": "/api/notifications/:path*",     "destination": "/api/notifications.js" },
    { "source": "/api/notifications",            "destination": "/api/notifications.js" },
    { "source": "/api/conversations/:path*",     "destination": "/api/conversations.js" },
    { "source": "/api/conversations",            "destination": "/api/conversations.js" },
    { "source": "/api/admin/:path*",             "destination": "/api/admin.js" },
    { "source": "/api/admin",                    "destination": "/api/admin.js" },
    { "source": "/api/reviews/:path*",           "destination": "/api/data.js" },
    { "source": "/api/reviews",                  "destination": "/api/data.js" },
    { "source": "/api/transactions/:path*",      "destination": "/api/data.js" },
    { "source": "/api/transactions",             "destination": "/api/data.js" },
    { "source": "/api/withdrawals/:path*",       "destination": "/api/data.js" },
    { "source": "/api/withdrawals",              "destination": "/api/data.js" },
    { "source": "/api/disputes/:path*",          "destination": "/api/data.js" },
    { "source": "/api/disputes",                 "destination": "/api/data.js" },
    { "source": "/api/timeline/:path*",          "destination": "/api/data.js" },
    { "source": "/api/timeline",                 "destination": "/api/data.js" },
    { "source": "/api/booking-photos/:path*",    "destination": "/api/jobs.js" },
    { "source": "/api/booking-photos",           "destination": "/api/jobs.js" },
    { "source": "/api/checklists/:path*",        "destination": "/api/jobs.js" },
