{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/auth/:action", "destination": "/api/auth.cjs?action=$1" },
    { "source": "/api/users/me/dashboard", "destination": "/api/users.cjs/me/dashboard" },
    { "source": "/api/users/me", "destination": "/api/users.cjs/me" },
    { "source": "/api/users/professionals/:id", "destination": "/api/users.cjs/professionals/$1" },
    { "source": "/api/users/professionals", "destination": "/api/users.cjs/professionals" },
    { "source": "/api/services/:slug", "destination": "/api/services.cjs/$1" },
    { "source": "/api/services", "destination": "/api/services.cjs" },
    { "source": "/api/bookings/available-slots", "destination": "/api/bookings.cjs/available-slots" },
    { "source": "/api/bookings/:id", "destination": "/api/bookings.cjs/$1" },
    { "source": "/api/bookings", "destination": "/api/bookings.cjs" },
    { "source": "/api/transactions/summary", "destination": "/api/transactions.cjs/summary" },
    { "source": "/api/transactions", "destination": "/api/transactions.cjs" },
    { "source": "/api/reviews", "destination": "/api/reviews.cjs" },
    { "source": "/api/booking", "destination": "/api/booking.cjs" },
    { "source": "/api/contact", "destination": "/api/contact.cjs" },
    { "source": "/api/join",    "destination": "/api/join.cjs"    },
    { "source": "/api/chat",    "destination": "/api/chat.js"     },
    { "source": "/api/(.*)",    "destination": "/api/$1"          },
    { "source": "/(.*)",        "destination": "/index.html"      }
  ]
}
