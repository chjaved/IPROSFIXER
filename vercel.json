{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/booking", "destination": "/api/booking.cjs" },
    { "source": "/api/contact", "destination": "/api/contact.cjs" },
    { "source": "/api/join",    "destination": "/api/join.cjs"    },
    { "source": "/api/chat",    "destination": "/api/chat.cjs"    },
    { "source": "/api/(.*)",    "destination": "/api/$1"          },
    { "source": "/(.*)",        "destination": "/index.html"      }
  ]
}
