{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/api/auth/(.*)",         "dest": "/api/auth.cjs" },
    { "src": "/api/auth",              "dest": "/api/auth.cjs" },
    { "src": "/api/users/(.*)",        "dest": "/api/users.cjs" },
    { "src": "/api/users",             "dest": "/api/users.cjs" },
    { "src": "/api/services/(.*)",     "dest": "/api/services.cjs" },
    { "src": "/api/services",          "dest": "/api/services.cjs" },
    { "src": "/api/bookings/(.*)",     "dest": "/api/bookings.cjs" },
    { "src": "/api/bookings",          "dest": "/api/bookings.cjs" },
    { "src": "/api/transactions/(.*)", "dest": "/api/transactions.cjs" },
    { "src": "/api/transactions",      "dest": "/api/transactions.cjs" },
    { "src": "/api/reviews/(.*)",      "dest": "/api/reviews.cjs" },
    { "src": "/api/reviews",           "dest": "/api/reviews.cjs" },
    { "src": "/api/contact",           "dest": "/api/contact.cjs" },
    { "src": "/api/join",              "dest": "/api/join.cjs" },
    { "src": "/api/chat",              "dest": "/api/chat.js" },
    { "src": "/(.*)",                  "dest": "/index.html" }
  ]
}
