{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/auth/:path*",         "destination": "/api/auth.cjs" },
    { "source": "/api/users",               "destination": "/api/users.cjs" },
    { "source": "/api/users/:path*",        "destination": "/api/users.cjs" },
    { "source": "/api/services",            "destination": "/api/services.cjs" },
    { "source": "/api/services/:path*",     "destination": "/api/services.cjs" },
    { "source": "/api/bookings",            "destination": "/api/bookings.cjs" },
    { "source": "/api/bookings/:path*",     "destination": "/api/bookings.cjs" },
    { "source": "/api/transactions",        "destination": "/api/transactions.cjs" },
    { "source": "/api/transactions/:path*", "destination": "/api/transactions.cjs" },
    { "source": "/api/reviews",             "destination": "/api/reviews.cjs" },
    { "source": "/api/reviews/:path*",      "destination": "/api/reviews.cjs" },
    { "source": "/api/contact",             "destination": "/api/contact.cjs" },
    { "source": "/api/join",                "destination": "/api/join.cjs" },
    { "source": "/api/chat",                "destination": "/api/chat.js" },
    { "source": "/(.*)",                    "destination": "/index.html" }
  ]
}
