{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/auth.cjs":         { "runtime": "nodejs18.x" },
    "api/users.cjs":        { "runtime": "nodejs18.x" },
    "api/bookings.cjs":     { "runtime": "nodejs18.x" },
    "api/services.cjs":     { "runtime": "nodejs18.x" },
    "api/reviews.cjs":      { "runtime": "nodejs18.x" },
    "api/transactions.cjs": { "runtime": "nodejs18.x" },
    "api/contact.cjs":      { "runtime": "nodejs18.x" },
    "api/join.cjs":         { "runtime": "nodejs18.x" },
    "api/chat.js":          { "runtime": "nodejs18.x" }
  },
  "routes": [
    { "src": "/api/auth/register-pro", "dest": "/api/auth.cjs" },
    { "src": "/api/auth/register",     "dest": "/api/auth.cjs" },
    { "src": "/api/auth/login",        "dest": "/api/auth.cjs" },
    { "src": "/api/auth/verify",       "dest": "/api/auth.cjs" },
    { "src": "/api/auth/(.*)",         "dest": "/api/auth.cjs" },
    { "src": "/api/users/me/dashboard","dest": "/api/users.cjs" },
    { "src": "/api/users/me",          "dest": "/api/users.cjs" },
    { "src": "/api/users/professionals","dest": "/api/users.cjs" },
    { "src": "/api/users/(.*)",        "dest": "/api/users.cjs" },
    { "src": "/api/users",             "dest": "/api/users.cjs" },
    { "src": "/api/bookings/(.*)",     "dest": "/api/bookings.cjs" },
    { "src": "/api/bookings",          "dest": "/api/bookings.cjs" },
    { "src": "/api/services/(.*)",     "dest": "/api/services.cjs" },
    { "src": "/api/services",          "dest": "/api/services.cjs" },
    { "src": "/api/transactions/summary","dest": "/api/transactions.cjs" },
    { "src": "/api/transactions/(.*)", "dest": "/api/transactions.cjs" },
    { "src": "/api/transactions",      "dest": "/api/transactions.cjs" },
    { "src": "/api/reviews/(.*)",      "dest": "/api/reviews.cjs" },
    { "src": "/api/reviews",           "dest": "/api/reviews.cjs" },
    { "src": "/api/contact",           "dest": "/api/contact.cjs" },
    { "src": "/api/join",              "dest": "/api/join.cjs" },
    { "src": "/api/chat",              "dest": "/api/chat.js" },
    { "src": "/(.*)",                  "dest": "/index.html" }
  ]
}
